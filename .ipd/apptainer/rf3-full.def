Bootstrap: localimage
From: .ipd/apptainer/rf3-dev.sif
IncludeCmd: yes

# RF3 Full Production Container - Includes modelhub, rf3, and atomworks packages installed

# To build this Apptainer, from the project root, run:
# apptainer build rf3-full.sif .ipd/apptainer/rf3-full.def

%labels
    Author Institute for Protein Design
    Version 1.0.0
    Description RosettaFold3 - Full production container with all packages installed

%setup
    # Copy minimal repo structure needed for building packages
    echo "Copying repository structure for build..."

    # Create base directory
    mkdir -p ${APPTAINER_ROOTFS}/opt/build

    # Copy .git for version detection
    rsync -av --info=progress2 .git/ ${APPTAINER_ROOTFS}/opt/build/.git/

    # Copy LICENSE and README files
    cp LICENSE.md ${APPTAINER_ROOTFS}/opt/build/
    cp README.md ${APPTAINER_ROOTFS}/opt/build/

    # Copy modelhub package (at repo root)
    cp pyproject.toml ${APPTAINER_ROOTFS}/opt/build/
    mkdir -p ${APPTAINER_ROOTFS}/opt/build/src/modelhub
    rsync -av --info=progress2 src/modelhub/ ${APPTAINER_ROOTFS}/opt/build/src/modelhub/

    # Copy rf3 package (in models/rf3/)
    mkdir -p ${APPTAINER_ROOTFS}/opt/build/models/rf3/src/rf3
    cp models/rf3/pyproject.toml ${APPTAINER_ROOTFS}/opt/build/models/rf3/
    cp models/rf3/README.md ${APPTAINER_ROOTFS}/opt/build/models/rf3/
    rsync -av --info=progress2 models/rf3/src/rf3/ ${APPTAINER_ROOTFS}/opt/build/models/rf3/src/rf3/

    # Copy atomworks package (in lib/atomworks/)
    mkdir -p ${APPTAINER_ROOTFS}/opt/build/lib/atomworks/src/atomworks
    cp lib/atomworks/pyproject.toml ${APPTAINER_ROOTFS}/opt/build/lib/atomworks/
    cp lib/atomworks/LICENSE.md ${APPTAINER_ROOTFS}/opt/build/lib/atomworks/
    cp lib/atomworks/README.md ${APPTAINER_ROOTFS}/opt/build/lib/atomworks/
    rsync -av --info=progress2 lib/atomworks/src/atomworks/ ${APPTAINER_ROOTFS}/opt/build/lib/atomworks/src/atomworks/

    echo "Repository structure copied successfully."

%post
    echo "Installing packages into container..."

    # Install modelhub from repo root (no dependencies - already in base image)
    echo "Installing modelhub..."
    cd /opt/build
    uv pip install --system --break-system-packages --no-deps .

    # Install rf3 (no dependencies - already in base image)
    echo "Installing rf3..."
    cd /opt/build/models/rf3
    uv pip install --system --break-system-packages --no-deps .

    # Install atomworks (no dependencies - already in base image)
    echo "Installing atomworks..."
    cd /opt/build/lib/atomworks
    uv pip install --system --break-system-packages --no-deps .

    # Clean up build directory to minimize container size
    echo "Cleaning up build files..."
    cd /
    rm -rf /opt/build

    # Additional cleanup
    uv cache clean
    pip cache purge
    apt-get clean
    rm -rf /var/lib/apt/lists/* 2>/dev/null || true
    rm -rf /root/.cache 2>/dev/null || true
    rm -rf /opt/*.txt 2>/dev/null || true

    echo "Package installation complete."

%runscript
    # Simple runscript - just run Python with any arguments
    exec python "$@"

%help
    RosettaFold3 (RF3) full production container.

    Contains modelhub, rf3, and atomworks packages installed in site-packages.
    All dependencies are included from the base rf3-dev container.

    Usage:
        apptainer exec --nvccli rf3-full.sif rf3 fold inputs="example.json"
