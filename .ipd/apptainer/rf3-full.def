Bootstrap: localimage
From: .ipd/apptainer/rf3-dev.sif
IncludeCmd: yes

# RF3 Full Installation Container - Editable installs of modelhub and RF3

# To build this Apptainer, from the project root, run:
# apptainer build rf3-full.sif .ipd/apptainer/rf3-full.def

%labels
    Author Institute for Protein Design
    Version 1.0-full
    Description RosettaFold3 - Full installation for inference

%files
    # Copy only essential files (not .venv, or build artifacts)
    pyproject.toml /opt/modelhub/
    LICENSE.md /opt/modelhub/
    README.md /opt/modelhub/
    .project-root /opt/modelhub/
    src /opt/modelhub/
    models /opt/modelhub/
    lib /opt/modelhub/
    .ipd /opt/modelhub/
    .git /opt/modelhub/

%post
    # Editable install of core modelhub
    cd /opt/modelhub
    uv pip install --system --break-system-packages -e . --no-deps

    # Editable install of RF3
    uv pip install --system --break-system-packages -e models/rf3 --no-deps

%environment
    # (Flag to increase accessible GPU memory)
    export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

    # (Turn off NVLink)
    export NCCL_P2P_DISABLE=1

%runscript
   # NOTE: The %runscript is invoked when the container is run without specifying a different command.
   exec python "$@"

%help
    RosettaFold3 (RF3) full installation container with editable installs.
