Bootstrap: localimage
From: .ipd/apptainer/rf3-dev.sif
IncludeCmd: yes

# RFD3 Full Production Container - Includes modelhub, rfd3, and atomworks packages installed

# To build this Apptainer, from the project root, run:
# apptainer build rfd3-full.sif .ipd/apptainer/rfd3-full.def

%labels
    Author Institute for Protein Design
    Version 1.0.0
    Description RFDiffusion3 - Full production container with all packages installed

%setup
    # Copy entire repository to container
    echo "Copying repository..."

    # Create base directory
    mkdir -p ${APPTAINER_ROOTFS}/opt/modelhub

    # Copy everything except large/unnecessary files
    rsync -av --info=progress2 \
        --exclude='.venv' \
        --exclude='__pycache__' \
        --exclude='*.pyc' \
        --exclude='.pytest_cache' \
        --exclude='*.egg-info' \
        --exclude='.ruff_cache' \
        --exclude='outputs' \
        --exclude='logs' \
        --exclude='*.sif' \
        --exclude='distillation' \
        --exclude='benchmarks' \
        --exclude='**/slurm_logs' \
        ./ ${APPTAINER_ROOTFS}/opt/modelhub/

    echo "Repository copied successfully."

%post
    echo "Installing packages into container..."

    # Do editable installs so everything works as in development
    cd /opt/modelhub

    # Install modelhub (editable, no dependencies - already in base image)
    echo "Installing modelhub..."
    uv pip install --system --break-system-packages --no-deps -e .[all]

    # Install rfd3 (editable, no dependencies - already in base image)
    echo "Installing rfd3..."
    cd /opt/modelhub/models/rfd3
    uv pip install --system --break-system-packages --no-deps -e .

    # Install atomworks (editable, no dependencies - already in base image)
    echo "Installing atomworks..."
    cd /opt/modelhub/lib/atomworks
    uv pip install --system --break-system-packages --no-deps -e .

    # Cleanup caches only
    echo "Cleaning up caches..."
    uv cache clean
    pip cache purge
    apt-get clean
    rm -rf /var/lib/apt/lists/* 2>/dev/null || true
    rm -rf /root/.cache 2>/dev/null || true

    echo "Package installation complete."

%runscript
    # Simple runscript - just run Python with any arguments
    exec python "$@"

%help
    RFDiffusion3 (RFD3) full production container.

    Contains modelhub, rfd3, and atomworks packages installed in site-packages.
    All dependencies are included from the base rf3-dev container.

    Usage:
        apptainer exec --nvccli rfd3-full.sif rfd3 run_inference inputs="example.json"
